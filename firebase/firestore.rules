rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // items: 필드 화이트리스트 + 불변 필드 보호
    match /items/{itemId} {
      function itemFieldsValid() {
        return request.resource.data.keys().hasOnly([
          'type', 'status', 'category', 'title', 'description', 'location',
          'lostDate', 'imageUrls', 'visionLabels', 'embeddingId',
          'verificationQ', 'verificationAHash',
          'userId', 'userName', 'createdAt'
        ]);
      }

      allow read: if request.auth != null;

      allow create: if request.auth != null
        && request.resource.data.userId == request.auth.uid
        && itemFieldsValid()
        && request.resource.data.status == 'active';

      allow update: if request.auth != null
        && resource.data.userId == request.auth.uid
        && itemFieldsValid()
        // 불변 필드 보호
        && request.resource.data.userId == resource.data.userId
        && request.resource.data.createdAt == resource.data.createdAt
        && request.resource.data.expiresAt == resource.data.expiresAt
        && request.resource.data.verificationAHash == resource.data.verificationAHash;

      allow delete: if false;
    }

    // matches: 登录可读，只有 admin SDK (Cloud Functions) 可写
    match /matches/{matchId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // users: 只能读写自己的文档
    match /users/{userId} {
      allow read, write: if request.auth != null
        && request.auth.uid == userId;
    }

    // verificationAttempts: 只能服务端写入，用户只能读自己的记录
    match /verificationAttempts/{attemptId} {
      allow read: if request.auth != null
        && resource.data.userId == request.auth.uid;
      allow write: if false;
    }
  }
}
